{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "paths": {
      "@xmcp/*": ["./.xmcp/*"]
    }
  },
  "include": ["src/**/*", "xmcp.config.ts", "xmcp-env.d.ts", ".xmcp/**/*"],
  "exclude": ["node_modules", "dist"]
}
