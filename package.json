{
  "name": "photon-mcp",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "start": "pnpm -r --parallel start",
    "dev:imessage": "pnpm --filter @photon-mcp/imessage dev",
    "dev:gateway": "pnpm --filter @photon-mcp/gateway dev",
    "build:imessage": "pnpm --filter @photon-mcp/imessage build",
    "build:gateway": "pnpm --filter @photon-mcp/gateway build"
  }
}
